{
  // Cloudflare Workers Static Assets config for the admin dashboard SPA.
  // Build with `npm install && npm run build` (outputs ./dist), then
  // `npx wrangler deploy`. Set VITE_API_BASE_URL as a build variable.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lr-admin-dashboard",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
